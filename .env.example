# ── Required ─────────────────────────────────────────────────

# Discord bot token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# API key for the LLM provider (OpenAI by default)
LLM_API_KEY=

# API key for the embedding provider (same key as LLM if using OpenAI for both)
EMBED_API_KEY=

# ── Optional: Discord ────────────────────────────────────────

# Set to your server ID for instant slash-command sync during development.
# Leave unset in production for global sync (can take up to 1 hour).
# DISCORD_GUILD_ID=

# ── Optional: Slack ──────────────────────────────────────────

# Slack bot token (xoxb-...) and app-level token (xapp-...) for socket mode.
# Both are required to enable the Slack platform.
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# ── Optional: LLM ───────────────────────────────────────────

# Provider: "openai" (default), "anthropic", or "mock"
# LLM_PROVIDER=openai

# Model name passed to the provider
# LLM_MODEL=gpt-5.4

# ── Optional: Embeddings ────────────────────────────────────

# Provider: "openai" (default) or "mock"
# EMBED_PROVIDER=openai

# Model name for embeddings
# EMBED_MODEL=text-embedding-3-small

# ── Optional: Storage ───────────────────────────────────────

# Root directory for SQLite DB, vector index, and downloaded PDFs
# DATA_DIR=data

# ── Optional: RAG tuning ────────────────────────────────────

# CHUNK_SIZE=1024
# CHUNK_OVERLAP=200
# Wide candidate pool retrieved by vector search; postprocessors filter down.
# SIMILARITY_TOP_K=30
# Final number of chunks sent to the LLM for synthesis.
# SYNTHESIS_TOP_K=8

# ── Optional: Ingestion ─────────────────────────────────────

# RSS poll interval in seconds (minimum 60)
# POLL_INTERVAL_SECONDS=600

# ── Optional: Logging ───────────────────────────────────────

# LOG_LEVEL=INFO
